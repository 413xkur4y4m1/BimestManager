<!DOCTYPE html>
<html lang="es">
<head>
<%- include('../partials/head', { titulo: 'Iniciar sesion' }) %>
</head>
<body class="screen-auth">
  <div class="auth-brand">
    <h1>Bimest Manager</h1>
  </div>

  <%- include('../partials/logo') %>

  <main class="auth-form">
    <h2 class="auth-title">Iniciar sesion</h2>

    <div id="flash" class="flash" hidden></div>

    <form id="loginForm" autocomplete="on" novalidate>
      <div class="field">
        <input type="email" name="email" placeholder="Correo electronico" autocomplete="email" inputmode="email" required>
      </div>
      <div class="field">
        <input type="password" name="password" placeholder="Contrase&ntilde;a" autocomplete="current-password" minlength="8" required>
      </div>

      <div class="auth-link">
        <a href="#" id="forgot">&iquest;Olvidaste tu contrase&ntilde;a?</a>
      </div>

      <div style="height: 14px"></div>

      <button class="btn btn-primary" type="submit" id="submitBtn">Entrar</button>
    </form>

    <p class="auth-footer">
      &iquest;No tienes cuenta? <a href="/registro">Reg&iacute;strate</a>
    </p>
  </main>

  <script src="/js/common.js" defer></script>
  <script src="/js/auth.js" defer></script>
</body>
</html>

<!DOCTYPE html>
<html lang="es">
<head>
<%- include('../partials/head', { titulo: 'Mi Panel · Turismo' }) %>
</head>
<body class="screen-app">
<%- include('../partials/header', { titulo: 'Turismo' }) %>

<main class="app-content">
  <div id="flash" class="flash" hidden></div>

  <!-- ============== TAB: Inicio ============== -->
  <section data-tab="home">
    <h1 class="section-title" id="welcomeTitle">Mi panel</h1>
    <p class="section-subtitle" id="welcomeSub">Cargando...</p>

    <article class="card">
      <h3>Sesión activa</h3>
      <div id="sesion"><div class="empty-state">Cargando...</div></div>
    </article>

    <article class="card">
      <h3>Atajos</h3>
      <div class="btn-row">
        <a class="btn btn-secondary" href="#prestamos">Mis préstamos</a>
        <a class="btn btn-primary" href="#sesion">Solicitar material</a>
      </div>
    </article>
  </section>

  <!-- ============== TAB: Sesión ============== -->
  <section data-tab="sesion">
    <h1 class="section-title">Sesión</h1>
    <p class="section-subtitle">Materiales sugeridos y solicitud de préstamo.</p>

    <article class="card">
      <h3>Sesión activa</h3>
      <div id="sesionDetalle"><div class="empty-state">Cargando...</div></div>
    </article>

    <article class="card" id="cardSugerencias" hidden>
      <h3>Materiales sugeridos para la práctica</h3>
      <ul class="list" id="sugerenciasList"></ul>
    </article>

    <article class="card" id="cardSolicitar" hidden>
      <h3>Solicitar material</h3>
      <p class="muted" style="font-size:12px;margin:0 0 8px">Tu solicitud le llega al administrador. Hasta que la apruebe no se considera prestada.</p>
      <form id="formPrestamo" class="form-card">
        <label class="field-label" for="materialSel">Material</label>
        <div class="field">
          <select id="materialSel" name="material_id" required>
            <option value="">Selecciona un material...</option>
          </select>
        </div>
        <label class="field-label" for="cantidad">Cantidad</label>
        <div class="field">
          <input id="cantidad" name="cantidad" type="number" min="1" step="1" value="1" required>
        </div>
        <button type="submit" class="btn btn-primary" id="btnSolicitar">Enviar solicitud</button>
      </form>
    </article>
  </section>

  <!-- ============== TAB: Préstamos ============== -->
  <section data-tab="prestamos">
    <h1 class="section-title">Préstamos</h1>
    <p class="section-subtitle">Tus préstamos y adeudos.</p>

    <div class="subtabs" role="tablist" aria-label="Secciones de préstamos">
      <button type="button" class="is-active" data-subtab="pr-act">Activos</button>
      <button type="button" data-subtab="pr-deb">Adeudos</button>
      <button type="button" data-subtab="pr-hist">Historial</button>
    </div>

    <div data-subtab-panel="pr-act">
      <article class="card" id="prestamosBox">
        <h3>Préstamos activos</h3>
        <p class="muted" style="font-size:12px;margin:0 0 8px">Total: <span data-total>0</span> · Mostrando <span data-shown>0</span></p>
        <div class="field" style="margin-bottom:8px">
          <input data-search type="search" placeholder="Buscar por material o práctica..." autocomplete="off">
        </div>
        <div data-filters style="display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap">
          <select data-filter="estado" style="padding:6px 10px;border-radius:10px;border:1px solid var(--c-line);font-size:13px">
            <option value="">Todos</option>
            <option value="PENDIENTE">Por aprobar</option>
            <option value="PRESTADO">Prestados</option>
            <option value="ADEUDO">Adeudos</option>
          </select>
        </div>
        <ul class="list" data-list><li class="empty-state">Sin préstamos.</li></ul>
        <div class="btn-row" data-pagination style="justify-content:center;margin-top:10px" hidden>
          <button type="button" class="btn btn-mini btn-ghost" data-prev>« Anterior</button>
          <span class="muted" data-info style="font-size:12px;align-self:center">Página 1 / 1</span>
          <button type="button" class="btn btn-mini btn-ghost" data-next>Siguiente »</button>
        </div>
      </article>
    </div>

    <div data-subtab-panel="pr-deb" hidden>
      <article class="card" id="adeudosBox">
        <h3>Mis adeudos</h3>
        <p class="muted" style="font-size:12px;margin:0 0 8px">Total: <span data-total>0</span> · Mostrando <span data-shown>0</span></p>
        <div class="field" style="margin-bottom:10px">
          <input data-search type="search" placeholder="Buscar por material..." autocomplete="off">
        </div>
        <ul class="list" data-list><li class="empty-state">Sin adeudos.</li></ul>
        <div class="btn-row" data-pagination style="justify-content:center;margin-top:10px" hidden>
          <button type="button" class="btn btn-mini btn-ghost" data-prev>« Anterior</button>
          <span class="muted" data-info style="font-size:12px;align-self:center">Página 1 / 1</span>
          <button type="button" class="btn btn-mini btn-ghost" data-next>Siguiente »</button>
        </div>
      </article>
    </div>

    <div data-subtab-panel="pr-hist" hidden>
      <article class="card" id="historialBox">
        <h3>Historial</h3>
        <p class="muted" style="font-size:12px;margin:0 0 8px">Total: <span data-total>0</span> · Mostrando <span data-shown>0</span></p>
        <div class="field" style="margin-bottom:10px">
          <input data-search type="search" placeholder="Buscar por material o práctica..." autocomplete="off">
        </div>
        <ul class="list" data-list><li class="empty-state">Sin historial.</li></ul>
        <div class="btn-row" data-pagination style="justify-content:center;margin-top:10px" hidden>
          <button type="button" class="btn btn-mini btn-ghost" data-prev>« Anterior</button>
          <span class="muted" data-info style="font-size:12px;align-self:center">Página 1 / 1</span>
          <button type="button" class="btn btn-mini btn-ghost" data-next>Siguiente »</button>
        </div>
      </article>
    </div>
  </section>

  <!-- ============== TAB: Avisos ============== -->
  <section data-tab="avisos">
    <h1 class="section-title">Avisos</h1>
    <p class="section-subtitle">Notificaciones del laboratorio de turismo.</p>

    <article class="card" id="notifBox">
      <h3>Notificaciones</h3>
      <p class="muted" style="font-size:12px;margin:0 0 8px">Total: <span data-total>0</span> · Mostrando <span data-shown>0</span></p>
      <div class="field" style="margin-bottom:8px">
        <input data-search type="search" placeholder="Buscar en notificaciones..." autocomplete="off">
      </div>
      <div data-filters style="display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap">
        <select data-filter="leido" style="padding:6px 10px;border-radius:10px;border:1px solid var(--c-line);font-size:13px">
          <option value="">Todas</option>
          <option value="no">No leídas</option>
          <option value="si">Leídas</option>
        </select>
      </div>
      <ul class="list" data-list><li class="empty-state">Sin notificaciones.</li></ul>
      <div class="btn-row" data-pagination style="justify-content:center;margin-top:10px" hidden>
        <button type="button" class="btn btn-mini btn-ghost" data-prev>« Anterior</button>
        <span class="muted" data-info style="font-size:12px;align-self:center">Página 1 / 1</span>
        <button type="button" class="btn btn-mini btn-ghost" data-next>Siguiente »</button>
      </div>
    </article>
  </section>
</main>

<%- include('../partials/bottom-nav', {
  active: 'home',
  navItems: [
    { key: 'home',  label: 'Inicio',     href: '#home',
      icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l9-8 9 8"/><path d="M5 10v10h14V10"/></svg>' },
    { key: 'sesion', label: 'Sesión', href: '#sesion',
      icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>' },
    { key: 'logo', label: '', href: '#home', center: true,
      icon: '<svg viewBox="0 0 200 120" aria-hidden="true"><g fill="none" stroke-width="14" stroke-linecap="round" stroke-linejoin="round"><circle cx="60" cy="60" r="38" stroke="#1d5e6e"/><circle cx="140" cy="60" r="38" stroke="#e07338"/></g></svg>' },
    { key: 'prestamos', label: 'Préstamos', href: '#prestamos',
      icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14l-4-2-4 2-4-2-4 2V6a2 2 0 0 1 2-2h2"/><line x1="9" y1="3" x2="15" y2="3"/></svg>' },
    { key: 'avisos', label: 'Avisos', href: '#avisos',
      icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 1 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>' }
  ]
}) %>

<script src="/js/common.js" defer></script>
<script src="/js/turismo-estudiante.js" defer></script>
</body>
</html>

<header class="app-header">
  <div class="app-header__avatar" id="appAvatar" aria-label="Perfil">--</div>
  <div class="app-header__title" id="appTitle"><%= typeof titulo !== 'undefined' ? titulo : 'Bimest Manager' %></div>
  <nav class="app-header__actions" aria-label="Acciones">
    <button type="button" class="app-header__action" id="btnRefresh" aria-label="Actualizar">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 3-6.7"/><polyline points="3 4 3 9 8 9"/></svg>
    </button>
    <button type="button" class="app-header__action" id="btnLogout" aria-label="Cerrar sesion">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
    </button>
  </nav>
</header>

# Cifrado TLS para MySQL. Pon DB_SSL=true cuando el server DB tenga certs.
DB_SSL=false
DB_SSL_CA=./certs/mysql-ca.pem
DB_SSL_REJECT_UNAUTHORIZED=true

# ============ JWT ============
JWT_SECRET=cambia_esto_por_uno_largo_y_aleatorio

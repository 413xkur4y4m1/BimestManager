# ============ Servidor ============
PORT=3307
HTTPS_PORT=4443
HTTPS_ENABLED=true
HTTPS_CN=localhost
NODE_ENV=development
LOG_LEVEL=info

# ============ Base de datos ============
# Usuario de aplicación con permisos mínimos (NO root). Ver sql/usuario_app.sql
DB_HOST=localhost

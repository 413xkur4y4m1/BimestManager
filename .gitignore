# Dependencias
node_modules/

# Variables de entorno (NUNCA subir secretos)
.env
.env.local
.env.*.local

# Certificados generados (autofirmados)
certs/server.key
certs/server.crt
certs/*.pem

# Logs
logs/
*.log
npm-debug.log*

# Firmas digitales de alumnos (datos personales, NO se versionan)
imageFirma/*
